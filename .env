# ============================================================
#  LMS Platform — Development Environment Variables
# ============================================================

# Django Core
SECRET_KEY=django-insecure-dev-key-lms-platform-2026-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_SETTINGS_MODULE=config.settings.local

# Database (SQLite — lokal development)
DATABASE_URL=sqlite:///db.sqlite3

# Redis (lokal development-da istifadə edilmir — LocMemCache işlədilir)
REDIS_URL=redis://localhost:6379/0

# GitHub Integration
GITHUB_TOKEN=ghp_placeholder
GITHUB_TEACHER_USERNAME=teacher

# YouTube Data API v3
YOUTUBE_API_KEY=placeholder

# Google Meet / Calendar
GOOGLE_CLIENT_ID=placeholder
GOOGLE_CLIENT_SECRET=placeholder
GOOGLE_REDIRECT_URI=http://localhost:8000/oauth/google/callback/

# Stripe (Ödəniş)
STRIPE_PUBLIC_KEY=pk_test_placeholder
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# Email (Development — console backend)
SENDGRID_API_KEY=placeholder
DEFAULT_FROM_EMAIL=noreply@lms.local

# SMS (Twilio — opsional)
TWILIO_ACCOUNT_SID=placeholder
TWILIO_AUTH_TOKEN=placeholder
TWILIO_PHONE_NUMBER=+1234567890

# DigitalOcean Spaces (Development-da lokal saxlama istifadə edilir)
AWS_ACCESS_KEY_ID=placeholder
AWS_SECRET_ACCESS_KEY=placeholder
AWS_STORAGE_BUCKET_NAME=lms-platform
AWS_S3_ENDPOINT_URL=https://fra1.digitaloceanspaces.com
AWS_S3_REGION_NAME=fra1

# Sentry (Development-da deaktiv)
SENTRY_DSN=

# LMS Biznes Parametrləri
LESSON_PRICE_AZN=25.00
CANCELLATION_HOURS=24
MAX_LESSONS_PER_WEEK=7
TRIAL_LESSON_DISCOUNT=50
