# ============================================================
#  LMS Platform — Environment Variables Template
#  Kopyalayın: cp .env.example .env
# ============================================================

# Django Core
SECRET_KEY=django-insecure-change-me-in-production-use-strong-random-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# Database (PostgreSQL)
DATABASE_URL=postgresql://lms_user:lms_password@localhost:5432/lms_db

# Redis
REDIS_URL=redis://localhost:6379/0

# GitHub Integration
GITHUB_TOKEN=ghp_your_github_personal_access_token
GITHUB_TEACHER_USERNAME=your_github_username

# YouTube Data API v3
YOUTUBE_API_KEY=AIza_your_youtube_api_key

# Google Meet / Calendar
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/oauth/google/callback/

# Stripe (Ödəniş)
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ePoint Payment Gateway (https://epoint.az)
EPOINT_PUBLIC_KEY=your_epoint_public_key
EPOINT_PRIVATE_KEY=your_epoint_private_key
SITE_URL=http://localhost:8000

# Email (Gmail SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=pragmatecheduaz@gmail.com
EMAIL_HOST_PASSWORD=your_gmail_app_password
DEFAULT_FROM_EMAIL=PragmaLife <pragmatecheduaz@gmail.com>

# SMS (Twilio — opsional)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# DigitalOcean Spaces (Fayl saxlama)
AWS_ACCESS_KEY_ID=your_spaces_access_key
AWS_SECRET_ACCESS_KEY=your_spaces_secret_key
AWS_STORAGE_BUCKET_NAME=lms-platform
AWS_S3_ENDPOINT_URL=https://fra1.digitaloceanspaces.com
AWS_S3_REGION_NAME=fra1

# Sentry (Production xəta izləmə)
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id

# LMS Biznes Parametrləri
LESSON_PRICE_AZN=25.00
CANCELLATION_HOURS=24
MAX_LESSONS_PER_WEEK=7
TRIAL_LESSON_DISCOUNT=50
