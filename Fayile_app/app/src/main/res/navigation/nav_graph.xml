<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <!-- AUTH -->
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.lms.app.ui.auth.LoginFragment"
        android:label="Daxil ol">
        <action
            android:id="@+id/action_login_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_login_to_register"
            app:destination="@id/registerFragment" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.lms.app.ui.auth.RegisterFragment"
        android:label="Qeydiyyat">
        <action
            android:id="@+id/action_register_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/registerFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- DASHBOARD -->
    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.lms.app.ui.dashboard.DashboardFragment"
        android:label="Ana səhifə" />

    <!-- BOOKINGS -->
    <fragment
        android:id="@+id/bookingListFragment"
        android:name="com.lms.app.ui.bookings.BookingListFragment"
        android:label="Dərslər">
        <action
            android:id="@+id/action_bookings_to_calendar"
            app:destination="@id/bookingCalendarFragment" />
    </fragment>

    <fragment
        android:id="@+id/bookingCalendarFragment"
        android:name="com.lms.app.ui.bookings.BookingCalendarFragment"
        android:label="Dərs sifariş et" />

    <!-- COURSES -->
    <fragment
        android:id="@+id/courseListFragment"
        android:name="com.lms.app.ui.courses.CourseListFragment"
        android:label="Kurslar" />

    <!-- NOTIFICATIONS -->
    <fragment
        android:id="@+id/notificationsFragment"
        android:name="com.lms.app.ui.notifications.NotificationsFragment"
        android:label="Bildirişlər" />

    <!-- PROFILE -->
    <fragment
        android:id="@+id/profileFragment"
        android:name="com.lms.app.ui.profile.ProfileFragment"
        android:label="Profil" />

</navigation>

